# Supabase configuration (client-side, VITE_ prefixed = public by design)
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# Izipay embedded form public key (client-side, public by design).
# Format: <shopId>:publickey_xxx (production) or <shopId>:testpublickey_xxx (test).
# Set per environment in Vercel: test key for "preview", production key for "production".
VITE_IZIPAY_PUBLIC_KEY=your-shopid:testpublickey_xxx
